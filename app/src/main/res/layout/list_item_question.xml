<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:elevation="7dp"
    android:background="@drawable/bg_rect_r5_ques"
    android:layout_height="46dp">

    <ImageView
        android:id="@+id/ivQuestionTypeLiCat"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_multi_choice"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvQuestionNoLiCat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif"
        android:textColorHint="@color/greenish_grey"
        android:hint="@string/demoNumber"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ivQuestionTypeLiCat"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvQuestionLiCat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:hint="@string/tvQuestion"
        android:maxLines="1"
        android:textColor="@color/white"
        android:textColorHint="@color/greenish_grey"
        app:layout_constraintBottom_toBottomOf="@+id/tvQuestionNoLiCat"
        app:layout_constraintEnd_toStartOf="@+id/ivTakeStatusLiCat"
        app:layout_constraintStart_toEndOf="@+id/tvQuestionNoLiCat"
        app:layout_constraintTop_toTopOf="@+id/tvQuestionNoLiCat" />

    <ImageView
        android:id="@+id/ivEditLiCat"
        android:layout_width="40dp"
        android:layout_height="30dp"
        android:padding="5dp"
        android:src="@drawable/ic_edit"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivTakeStatusLiCat"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:visibility="gone"
        android:background="@drawable/bg_rnd"
        android:backgroundTint="@color/white"
        android:src="@drawable/ic_check"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ivEditLiCat"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/green" />
</androidx.constraintlayout.widget.ConstraintLayout>